  "keyFeatures": [
    "Geolocation-based incident reporting with photo uploads",
    "Multi-role user system (Citizens, Municipality, Stores, Admin)",
    "Gamification with points and rewards system",
    "Real-time push notifications via FCM",
    "AI-powered incident classification",
    "Coupon redemption marketplace",
    "Angular-based admin dashboard",
    "PostgreSQL database with comprehensive data model",
    "Spring Boot REST API backend",
    "Incident tracking and status management"
  ],
  "publicApiSurface": [
    "POST /auth/login - User authentication",
    "POST /auth/register - User registration",
    "GET /reporte - List incident reports",
    "POST /reporte - Create new incident report",
    "PUT /reporte/{id} - Update incident report",
    "GET /usuario - Get user profile",
    "PUT /usuario/{id} - Update user profile",
    "GET /cupon - List available coupons",
    "POST /usuario-cupon - Redeem coupon",
    "GET /usuario-cupon - Get user's coupons",
    "GET /notificacion - List notifications",
    "POST /notificacion - Send notification",
    "GET /distrito - List districts",
    "GET /tipo-incidentes - List incident types",
    "GET /tipo-clasificacion - List classification types",
    "GET /categoria - List coupon categories",
    "GET /tienda - List partner stores"
  ]
